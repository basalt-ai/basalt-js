# Basalt API Configuration
# Get your API key at https://app.getbasalt.ai
BASALT_API_KEY=your_basalt_api_key_here

# OpenAI API Configuration
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Override Basalt API URL
# Default: https://api.getbasalt.ai
# For local development, uncomment and set to your local URL:
# BASALT_BASE_URL=http://localhost:3000

# Optional: OpenTelemetry Configuration
# OTLP gRPC collector endpoint (default: localhost:4317)
# BASALT_OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317
