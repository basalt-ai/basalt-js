{
	"compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "lib": ["ES2022"],
		"strict": false,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
        "moduleResolution": "Node16"
	},
	"include": ["*.ts"],
	"exclude": ["node_modules"]
}
